# Variables para docker-compose.prod.yml. Copia a .env.prod y rellena.
# (Genera los secretos: openssl rand -base64 48  /  openssl rand -hex 32)

# Base de datos
MYSQL_ROOT_PASSWORD=pon-un-root-seguro
MYSQL_DATABASE=crm_buhardilla
MYSQL_USER=crm
MYSQL_PASSWORD=pon-una-password-segura

# App
FRONTEND_URL=https://crm.tudominio.com
JWT_ACCESS_SECRET=genera-un-secreto-largo
JWT_REFRESH_SECRET=genera-OTRO-secreto-largo
ENCRYPTION_KEY=genera-32-bytes-en-hex-64-chars
CONTROL_PASSWORD=Buhardilla

# Admin inicial (seed)
SEED_ADMIN_EMAIL=labuhardillamkt@gmail.com
SEED_ADMIN_PASSWORD=cambia-esto
ADMIN_EMAIL_DOMAIN=labuhardilla.com

# Puerto público del frontend (nginx)
WEB_PORT=8080

// Schema Prisma — CRM La Buhardilla del Marketing
// Fase 1: autenticación y roles. Los módulos siguientes (clientes, reloj,
// potenciales, etc.) añadirán sus modelos en migraciones posteriores.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  TRABAJADOR
}

enum AccionTiempo {
  SEO
  WEB
  RRSS
  DISENO
  INFORMES
  SEO_LOCAL
  ADS
  ADMINISTRACION
  ESTRATEGIA
  EMAIL_MARKETING
}

enum TipoTablero {
  INFORMACION
  ADS
  SEO
  WEB
  DISENO
  REDES
  ESTRATEGICO
  AUDIOVISUAL
}

enum EstadoTarjeta {
  PENDIENTE
  EN_CURSO
  HECHO
}

enum SeccionClave {
  CLAVE
  SERVIDOR
}

/// Usuarios del CRM. El rol se asigna en el registro según la tabla RoleEmail.
model Usuario {
  id           String   @id @default(uuid())
  nombre       String   @db.VarChar(120)
  email        String   @unique @db.VarChar(180)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  rol          Rol      @default(TRABAJADOR)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  fichajes         Fichaje[]        @relation("FichajesPropios")
  fichajesEditados Fichaje[]        @relation("FichajesEditados")
  registrosTiempo  RegistroTiempo[]
  comentarios      Comentario[]
  archivos         Archivo[]
  asignaciones     AsignacionTarjeta[]

  @@map("usuarios")
}

/// Cliente de la agencia. En la Fase 2 se usa para el cronómetro; la Fase 3
/// (módulo Clientes) lo extenderá con tableros, datos sensibles, etc.
model Cliente {
  id        String   @id @default(uuid())
  nombre    String   @unique @db.VarChar(160)
  contacto  String?  @db.VarChar(255)
  notas     String?  @db.Text
  /// Datos sensibles cifrados con AES-256-GCM (solo accesibles desde "Control").
  datosSensibles String? @map("datos_sensibles") @db.Text
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  registrosTiempo RegistroTiempo[]
  tableros        Tablero[]
  claves          ClaveCliente[]

  @@map("clientes")
}

/// Hoja de claves del cliente (tipo Excel), separada por claves y servidores.
/// Los campos `usuario`, `secreto` y `notas` van cifrados (AES-256-GCM) y solo
/// son accesibles desde "Control" (admin + token de control).
model ClaveCliente {
  id        String       @id @default(uuid())
  clienteId String       @map("cliente_id")
  seccion   SeccionClave
  etiqueta  String       @db.VarChar(200)
  url       String?      @db.VarChar(500)
  usuario   String?      @db.Text
  secreto   String?      @db.Text
  notas     String?      @db.Text
  orden     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, seccion])
  @@map("claves_cliente")
}

/// Tablero tipo Trello de un cliente. Un tablero por tipo y cliente.
model Tablero {
  id        String      @id @default(uuid())
  clienteId String      @map("cliente_id")
  tipo      TipoTablero
  createdAt DateTime    @default(now()) @map("created_at")

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tarjetas Tarjeta[]

  @@unique([clienteId, tipo])
  @@map("tableros")
}

/// Tarjeta de un tablero. Estado (columna), fechas, progreso 0-100.
model Tarjeta {
  id          String        @id @default(uuid())
  tableroId   String        @map("tablero_id")
  titulo      String        @db.VarChar(200)
  descripcion String?       @db.Text
  estado      EstadoTarjeta @default(PENDIENTE)
  fechaInicio DateTime?     @map("fecha_inicio")
  fechaFin    DateTime?     @map("fecha_fin")
  progreso    Int           @default(0)
  orden       Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tablero       Tablero             @relation(fields: [tableroId], references: [id], onDelete: Cascade)
  comentarios   Comentario[]
  checklistItems ChecklistItem[]
  archivos      Archivo[]
  asignaciones  AsignacionTarjeta[]

  @@index([tableroId, estado])
  @@map("tarjetas")
}

/// Comentario / chat de una tarjeta.
model Comentario {
  id        String   @id @default(uuid())
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  texto     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("comentarios")
}

/// Ítem de checklist de una tarjeta.
model ChecklistItem {
  id         String   @id @default(uuid())
  tarjetaId  String   @map("tarjeta_id")
  texto      String   @db.VarChar(300)
  completado Boolean  @default(false)
  orden      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("checklist_items")
}

/// Archivo adjunto a una tarjeta (guardado en disco vía StorageService).
model Archivo {
  id        String   @id @default(uuid())
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  nombre    String   @db.VarChar(255)
  ruta      String   @db.VarChar(255)
  mime      String   @db.VarChar(120)
  tamano    Int
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("archivos")
}

/// Asignación de un trabajador a una tarjeta (M:N).
model AsignacionTarjeta {
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([tarjetaId, usuarioId])
  @@map("asignaciones_tarjeta")
}

/// Registro de tiempo (estilo Toggl): tiempo dedicado por un usuario a un
/// cliente y una acción. `fin` null = cronómetro en marcha. Editable por su
/// dueño (y por un admin).
model RegistroTiempo {
  id          String       @id @default(uuid())
  usuarioId   String       @map("usuario_id")
  clienteId   String       @map("cliente_id")
  accion      AccionTiempo
  inicio      DateTime
  fin         DateTime?
  descripcion String?      @db.VarChar(255)
  createdAt   DateTime     @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  @@index([usuarioId, inicio])
  @@index([clienteId, inicio])
  @@map("registros_tiempo")
}

/// Lista editable por un admin que determina qué correos/dominios son ADMIN.
/// `patron` puede ser un email completo ("ana@ejemplo.com") o un dominio ("@ejemplo.com").
model RoleEmail {
  id        String   @id @default(uuid())
  patron    String   @unique @db.VarChar(180)
  rol       Rol      @default(ADMIN)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("role_emails")
}

/// Refresh tokens rotatorios. Se guarda solo el hash del token; al rotar se
/// revoca el anterior. Permite logout y detección de reutilización.
model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("refresh_tokens")
}

/// Fichaje de jornada (entrada/salida). El trabajador NO puede modificar las
/// marcas una vez creadas; solo un ADMIN puede editar inicio/fin (queda
/// registrado quién y cuándo lo editó).
model Fichaje {
  id        String    @id @default(uuid())
  usuarioId String    @map("usuario_id")
  inicio    DateTime
  fin       DateTime?
  editadoPorId String? @map("editado_por_id")
  editadoAt    DateTime? @map("editado_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario    Usuario  @relation("FichajesPropios", fields: [usuarioId], references: [id], onDelete: Cascade)
  editadoPor Usuario? @relation("FichajesEditados", fields: [editadoPorId], references: [id], onDelete: SetNull)

  @@index([usuarioId, inicio])
  @@map("fichajes")
}

// Schema Prisma — CRM La Buhardilla del Marketing
// Fase 1: autenticación y roles. Los módulos siguientes (clientes, reloj,
// potenciales, etc.) añadirán sus modelos en migraciones posteriores.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  TRABAJADOR
}

enum AccionTiempo {
  SEO
  WEB
  RRSS
  DISENO
  INFORMES
  SEO_LOCAL
  ADS
  ADMINISTRACION
  ESTRATEGIA
  EMAIL_MARKETING
}

enum TipoTablero {
  INFORMACION
  ADS
  SEO
  WEB
  DISENO
  REDES
  ESTRATEGICO
  AUDIOVISUAL
}

enum EstadoTarjeta {
  PENDIENTE
  EN_CURSO
  HECHO
}

enum SeccionClave {
  CLAVE
  SERVIDOR
}

enum TipoEnlace {
  ENLACE
  RED_SOCIAL
}

enum EstadoPotencial {
  NUEVO
  CONTACTADO
  PRESUPUESTO_ENVIADO
  ACEPTADO
  RECHAZADO
}

enum EstadoPresupuesto {
  BORRADOR
  ENVIADO
  ACEPTADO
  RECHAZADO
}

enum TipoNotificacion {
  TARJETA_ASIGNADA
  POTENCIAL
  REUNION
  LIMITE_HORAS
}

/// Usuarios del CRM. El rol se asigna en el registro según la tabla RoleEmail.
model Usuario {
  id           String   @id @default(uuid())
  nombre       String   @db.VarChar(120)
  email        String   @unique @db.VarChar(180)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  rol          Rol      @default(TRABAJADOR)
  activo       Boolean  @default(true)

  // Ficha de empleado (gestionada por el administrador)
  dni            String?  @db.VarChar(20)
  telefono       String?  @db.VarChar(30)
  puesto         String?  @db.VarChar(120)
  enPracticas    Boolean  @default(false) @map("en_practicas")
  contratoRuta   String?  @map("contrato_ruta") @db.VarChar(255)
  contratoNombre String?  @map("contrato_nombre") @db.VarChar(255)
  fotoRuta       String?  @map("foto_ruta") @db.VarChar(255)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  fichajes         Fichaje[]        @relation("FichajesPropios")
  fichajesEditados Fichaje[]        @relation("FichajesEditados")
  registrosTiempo  RegistroTiempo[]
  comentarios      Comentario[]
  archivos         Archivo[]
  asignaciones     AsignacionTarjeta[]
  potencialesCreados Potencial[]
  notificaciones   Notificacion[]
  documentos       DocumentoEmpleado[]

  @@map("usuarios")
}

/// Documento del expediente del empleado (contratos, DNI, etc.).
model DocumentoEmpleado {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  nombre    String   @db.VarChar(255)
  ruta      String   @db.VarChar(255)
  mime      String   @db.VarChar(120)
  tamano    Int
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("documentos_empleado")
}

/// Notificación dirigida a un usuario (p. ej. asignación de tarjeta con su
/// fecha de fin). Se emite también por WebSocket en tiempo real.
model Notificacion {
  id         String           @id @default(uuid())
  usuarioId  String           @map("usuario_id")
  tipo       TipoNotificacion
  mensaje    String           @db.VarChar(300)
  entidadTipo String?         @map("entidad_tipo") @db.VarChar(40)
  entidadId  String?          @map("entidad_id")
  fechaFin   DateTime?        @map("fecha_fin")
  leida      Boolean          @default(false)
  createdAt  DateTime         @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@map("notificaciones")
}

/// Cliente de la agencia. En la Fase 2 se usa para el cronómetro; la Fase 3
/// (módulo Clientes) lo extenderá con tableros, datos sensibles, etc.
model Cliente {
  id        String   @id @default(uuid())
  nombre    String   @unique @db.VarChar(160)
  contacto  String?  @db.VarChar(255)
  notas     String?  @db.Text
  logoRuta  String?  @map("logo_ruta") @db.VarChar(255)
  /// Datos sensibles cifrados con AES-256-GCM (solo accesibles desde "Control").
  datosSensibles String? @map("datos_sensibles") @db.Text
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  registrosTiempo RegistroTiempo[]
  tableros        Tablero[]
  claves          ClaveCliente[]
  potencialesConvertidos Potencial[]
  presupuestos    Presupuesto[]
  documentos      DocumentoCliente[]
  enlaces         EnlaceCliente[]
  limites         LimiteCliente[]

  @@map("clientes")
}

/// Límite de horas mensuales que se deben dedicar a un cliente por acción
/// (p. ej. SEO: 4h/mes). Solo avisa cuando se supera, no bloquea.
model LimiteCliente {
  id        String       @id @default(uuid())
  clienteId String       @map("cliente_id")
  accion    AccionTiempo
  horas     Float
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, accion])
  @@map("limites_cliente")
}

/// Documento adjunto a la ficha del cliente (cualquier empleado).
model DocumentoCliente {
  id        String   @id @default(uuid())
  clienteId String   @map("cliente_id")
  nombre    String   @db.VarChar(255)
  ruta      String   @db.VarChar(255)
  mime      String   @db.VarChar(120)
  tamano    Int
  createdAt DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("documentos_cliente")
}

/// Enlace de interés o red social del cliente.
model EnlaceCliente {
  id        String     @id @default(uuid())
  clienteId String     @map("cliente_id")
  tipo      TipoEnlace @default(ENLACE)
  etiqueta  String     @db.VarChar(120)
  url       String     @db.VarChar(500)
  createdAt DateTime   @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("enlaces_cliente")
}

/// Cliente potencial (lead) en el embudo de ventas. Solo lo gestionan admins.
model Potencial {
  id                  String          @id @default(uuid())
  nombre              String          @db.VarChar(160)
  contacto            String?         @db.VarChar(255)
  origen              String?         @db.VarChar(120)
  notas               String?         @db.Text
  estado              EstadoPotencial @default(NUEVO)
  clienteConvertidoId String?         @map("cliente_convertido_id")
  createdById         String?         @map("created_by_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  cliente      Cliente?      @relation(fields: [clienteConvertidoId], references: [id], onDelete: SetNull)
  createdBy    Usuario?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  presupuestos Presupuesto[]

  @@index([estado])
  @@map("potenciales")
}

/// Presupuesto enviado a un potencial (o cliente). La aceptación se hace desde
/// una página pública con un token único, sin necesidad de login.
model Presupuesto {
  id              String            @id @default(uuid())
  potencialId     String?           @map("potencial_id")
  clienteId       String?           @map("cliente_id")
  concepto        String            @db.VarChar(255)
  detalle         String?           @db.Text
  monto           Decimal           @db.Decimal(10, 2)
  estado          EstadoPresupuesto @default(BORRADOR)
  archivoRuta     String?           @map("archivo_ruta") @db.VarChar(255)
  archivoNombre   String?           @map("archivo_nombre") @db.VarChar(255)
  tokenAceptacion String?           @unique @map("token_aceptacion")
  aceptadoAt      DateTime?         @map("aceptado_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  potencial Potencial? @relation(fields: [potencialId], references: [id], onDelete: Cascade)
  cliente   Cliente?   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("presupuestos")
}

/// Hoja de claves del cliente (tipo Excel), separada por claves y servidores.
/// Los campos `usuario`, `secreto` y `notas` van cifrados (AES-256-GCM) y solo
/// son accesibles desde "Control" (admin + token de control).
model ClaveCliente {
  id        String       @id @default(uuid())
  clienteId String       @map("cliente_id")
  seccion   SeccionClave
  etiqueta  String       @db.VarChar(200)
  url       String?      @db.VarChar(500)
  usuario   String?      @db.Text
  secreto   String?      @db.Text
  notas     String?      @db.Text
  orden     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, seccion])
  @@map("claves_cliente")
}

/// Tablero tipo Trello de un cliente. Un tablero por tipo y cliente.
model Tablero {
  id        String      @id @default(uuid())
  clienteId String      @map("cliente_id")
  tipo      TipoTablero
  createdAt DateTime    @default(now()) @map("created_at")

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tarjetas Tarjeta[]

  @@unique([clienteId, tipo])
  @@map("tableros")
}

/// Tarjeta de un tablero. Estado (columna), fechas, progreso 0-100.
model Tarjeta {
  id          String        @id @default(uuid())
  tableroId   String        @map("tablero_id")
  titulo      String        @db.VarChar(200)
  descripcion String?       @db.Text
  estado      EstadoTarjeta @default(PENDIENTE)
  fechaInicio DateTime?     @map("fecha_inicio")
  fechaFin    DateTime?     @map("fecha_fin")
  progreso    Int           @default(0)
  orden       Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tablero       Tablero             @relation(fields: [tableroId], references: [id], onDelete: Cascade)
  comentarios   Comentario[]
  checklistItems ChecklistItem[]
  archivos      Archivo[]
  asignaciones  AsignacionTarjeta[]

  @@index([tableroId, estado])
  @@map("tarjetas")
}

/// Comentario / chat de una tarjeta.
model Comentario {
  id        String   @id @default(uuid())
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  texto     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("comentarios")
}

/// Ítem de checklist de una tarjeta.
model ChecklistItem {
  id         String   @id @default(uuid())
  tarjetaId  String   @map("tarjeta_id")
  texto      String   @db.VarChar(300)
  completado Boolean  @default(false)
  orden      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("checklist_items")
}

/// Archivo adjunto a una tarjeta (guardado en disco vía StorageService).
model Archivo {
  id        String   @id @default(uuid())
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  nombre    String   @db.VarChar(255)
  ruta      String   @db.VarChar(255)
  mime      String   @db.VarChar(120)
  tamano    Int
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([tarjetaId])
  @@map("archivos")
}

/// Asignación de un trabajador a una tarjeta (M:N).
model AsignacionTarjeta {
  tarjetaId String   @map("tarjeta_id")
  usuarioId String   @map("usuario_id")
  createdAt DateTime @default(now()) @map("created_at")

  tarjeta Tarjeta @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([tarjetaId, usuarioId])
  @@map("asignaciones_tarjeta")
}

/// Registro de tiempo (estilo Toggl): tiempo dedicado por un usuario a un
/// cliente y una acción. `fin` null = cronómetro en marcha. Editable por su
/// dueño (y por un admin).
model RegistroTiempo {
  id          String       @id @default(uuid())
  usuarioId   String       @map("usuario_id")
  clienteId   String       @map("cliente_id")
  accion      AccionTiempo
  inicio      DateTime
  fin         DateTime?
  descripcion String?      @db.VarChar(255)
  createdAt   DateTime     @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  @@index([usuarioId, inicio])
  @@index([clienteId, inicio])
  @@map("registros_tiempo")
}

/// Lista editable por un admin que determina qué correos/dominios son ADMIN.
/// `patron` puede ser un email completo ("ana@ejemplo.com") o un dominio ("@ejemplo.com").
model RoleEmail {
  id        String   @id @default(uuid())
  patron    String   @unique @db.VarChar(180)
  rol       Rol      @default(ADMIN)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("role_emails")
}

/// Refresh tokens rotatorios. Se guarda solo el hash del token; al rotar se
/// revoca el anterior. Permite logout y detección de reutilización.
model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("refresh_tokens")
}

/// Fichaje de jornada (entrada/salida). El trabajador NO puede modificar las
/// marcas una vez creadas; solo un ADMIN puede editar inicio/fin (queda
/// registrado quién y cuándo lo editó).
model Fichaje {
  id        String    @id @default(uuid())
  usuarioId String    @map("usuario_id")
  inicio    DateTime
  fin       DateTime?
  editadoPorId String? @map("editado_por_id")
  editadoAt    DateTime? @map("editado_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario    Usuario  @relation("FichajesPropios", fields: [usuarioId], references: [id], onDelete: Cascade)
  editadoPor Usuario? @relation("FichajesEditados", fields: [editadoPorId], references: [id], onDelete: SetNull)

  @@index([usuarioId, inicio])
  @@map("fichajes")
}

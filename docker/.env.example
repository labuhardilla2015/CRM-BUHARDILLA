# Variables que consume docker-compose.yml para levantar MySQL.
# Copia este archivo a docker/.env (ya está en .gitignore).
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=crm_buhardilla
MYSQL_USER=crm
MYSQL_PASSWORD=crmpassword
# Puerto del HOST hacia el MySQL del contenedor. Usa 3307 si ya tienes un
# MySQL nativo ocupando el 3306 en tu equipo.
MYSQL_PORT=3307

{
  "name": "crm-buhardilla",
  "version": "0.1.0",
  "private": true,
  "description": "CRM interno de La Buhardilla del Marketing",
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:logs": "docker compose -f docker/docker-compose.yml logs -f mysql",
    "backend:dev": "npm run start:dev -w backend",
    "frontend:dev": "npm run dev -w frontend",
    "shared:build": "npm run build -w @crm/shared",
    "dev": "npm run shared:build && concurrently -n backend,frontend -c blue,magenta \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
